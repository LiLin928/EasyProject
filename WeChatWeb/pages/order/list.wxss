/* pages/order/list.wxss */

.page-order-list {
  min-height: 100vh;
  background: #f7f8fa;
}

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #646566;
  position: relative;
}

.tab-item.active {
  color: #1989fa;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #1989fa;
  border-radius: 2rpx;
}

/* 订单列表 */
.order-list {
  padding: 20rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f7f8fa;
}

.order-no {
  font-size: 24rpx;
  color: #969799;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

/* 状态颜色 - 基于数字状态码 */
.status-1 { color: #ff976a; }  /* 待支付 */
.status-2 { color: #1989fa; }  /* 已支付 */
.status-3 { color: #07c160; }  /* 配送中 */
.status-4 { color: #07c160; }  /* 已完成 */
.status-5 { color: #969799; }  /* 已取消 */
.status-6 { color: #ee0a24; }  /* 退款中 */
.status-7 { color: #969799; }  /* 已退款 */

/* 商品 */
.order-goods {
  padding: 20rpx 30rpx;
}

.goods-item {
  display: flex;
  padding: 16rpx 0;
}

.goods-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #323233;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  color: #ee0a24;
}

.goods-count {
  font-size: 24rpx;
  color: #969799;
}

/* 订单底部 */
.order-footer {
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f7f8fa;
  text-align: right;
}

.order-total {
  font-size: 26rpx;
  color: #646566;
}

.order-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #ee0a24;
}

/* 操作按钮 */
.order-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f7f8fa;
}

.action-btn {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  border-radius: 32rpx;
  border: 1rpx solid #ebedf0;
  color: #646566;
}

.action-btn.primary {
  background: #1989fa;
  color: #fff;
  border-color: #1989fa;
}

.action-btn.cancel {
  color: #ee0a24;
  border-color: #ee0a24;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #969799;
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #969799;
}