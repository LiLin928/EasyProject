/* pages/chat/chat.wxss */

.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 连接状态 */
.connection-status {
  padding: 16rpx 24rpx;
  background: #fff3cd;
  text-align: center;
}

.status-text {
  font-size: 24rpx;
  color: #856404;
}

.status-text.error {
  color: #dc3545;
  background: #f8d7da;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.load-more {
  padding: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 消息项 */
.message-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.message-item.customer {
  justify-content: flex-end;
}

.message-item.staff {
  justify-content: flex-start;
}

/* 头像 */
.message-avatar {
  width: 64rpx;
  height: 64rpx;
  margin: 0 16rpx;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  background: #e0e0e0;
}

/* 消息气泡 */
.message-bubble {
  max-width: 60%;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  position: relative;
}

.message-item.staff .message-bubble {
  background: #fff;
  border: 1rpx solid #e0e0e0;
}

.message-item.customer .message-bubble {
  background: #1989fa;
  color: #fff;
}

/* 文字消息 */
.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

/* 图片消息 */
.message-image {
  max-width: 100%;
  min-width: 200rpx;
  border-radius: 8rpx;
}

/* 语音消息 */
.message-voice {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.voice-icon {
  font-size: 32rpx;
}

.voice-duration {
  font-size: 24rpx;
  color: #999;
}

.message-item.customer .voice-duration {
  color: rgba(255, 255, 255, 0.8);
}

/* 消息时间 */
.message-time {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
  text-align: right;
}

.message-item.staff .message-time {
  text-align: left;
}

/* 输入区域 */
.input-area {
  background: #fff;
  border-top: 1rpx solid #e0e0e0;
  padding: 16rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 消息类型切换 */
.type-tabs {
  display: flex;
  border-bottom: 1rpx solid #e0e0e0;
  padding-bottom: 16rpx;
  margin-bottom: 16rpx;
}

.type-tab {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  color: #666;
  border-radius: 8rpx;
}

.type-tab.active {
  background: #1989fa;
  color: #fff;
}

.tab-icon {
  font-size: 28rpx;
}

/* 文字输入 */
.text-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.text-input {
  flex: 1;
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.send-btn {
  height: 72rpx;
  line-height: 72rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 8rpx;
  padding: 0 24rpx;
}

/* 图片选择 */
.image-input-wrapper {
  display: flex;
  justify-content: center;
}

.choose-image-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 8rpx;
}

/* 语音录音 */
.voice-input-wrapper {
  display: flex;
  justify-content: center;
}

.record-btn {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #666;
}

.record-btn.recording {
  background: #1989fa;
  color: #fff;
}