/* pages/shopping/shopping.wxss */

.page-shopping {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 120rpx;
}

/* 空购物车 */
.empty-cart {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding: 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #969799;
  margin-bottom: 40rpx;
}

.empty-btn {
  padding: 20rpx 80rpx;
  background: linear-gradient(135deg, #1989fa 0%, #07c160 100%);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}

/* 顶部操作栏 */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #ebedf0;
}

.cart-count {
  font-size: 28rpx;
  color: #646566;
}

.top-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #1989fa;
}

.action-btn.danger {
  color: #ee0a24;
}

/* 购物车列表 */
.cart-items {
  padding: 20rpx;
}

.cart-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 选中框 */
.select-box {
  padding: 0 20rpx;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #c8c9cc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #fff;
}

.checkbox.checked {
  background: #1989fa;
  border-color: #1989fa;
}

/* 商品信息 */
.item-content {
  flex: 1;
  display: flex;
  padding: 0 20rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 28rpx;
  color: #323233;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #ee0a24;
}

.price-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ee0a24;
}

/* 数量控制 */
.count-control {
  display: flex;
  align-items: center;
  border: 1rpx solid #ebedf0;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

.count-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #323233;
  background: #f7f8fa;
}

.count-btn.disabled {
  color: #c8c9cc;
}

.count-value {
  width: 60rpx;
  text-align: center;
  font-size: 28rpx;
  color: #323233;
}

/* 删除按钮 */
.delete-btn {
  padding: 10rpx 20rpx;
  background: #ee0a24;
  color: #fff;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-left: 20rpx;
}

/* 底部结算栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all-text {
  font-size: 28rpx;
  color: #323233;
  margin-left: 12rpx;
}

.checkout-info {
  display: flex;
  align-items: center;
}

.total-price {
  margin-right: 20rpx;
}

.total-price .label {
  font-size: 28rpx;
  color: #323233;
}

.total-price .price-symbol {
  font-size: 24rpx;
  color: #ee0a24;
  margin-left: 8rpx;
}

.total-price .price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ee0a24;
}

.checkout-btn {
  padding: 20rpx 50rpx;
  background: linear-gradient(135deg, #ff6034 0%, #ee0a24 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 40rpx;
}

.checkout-btn.disabled {
  background: #c8c9cc;
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}