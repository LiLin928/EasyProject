/* pages/index/index.wxss */

.page-index {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 120rpx;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx 30rpx;
  background: #fff;
}

.search-input {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #969799;
  font-size: 28rpx;
}

/* 轮播图 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  background: #ebedf0;
}

/* 分类区域 */
.category-section {
  background: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #323233;
}

.section-more {
  font-size: 24rpx;
  color: #969799;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.category-item {
  width: calc(20% - 16rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.category-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  background: #f7f8fa;
}

.category-name {
  font-size: 24rpx;
  color: #323233;
}

/* 商品区域 */
.product-section {
  background: #fff;
  margin: 20rpx 0;
  padding: 30rpx;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.product-item {
  width: calc(50% - 10rpx);
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx 0;
}

.loading-text {
  color: #969799;
  font-size: 28rpx;
}