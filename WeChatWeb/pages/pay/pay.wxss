/* pages/pay/pay.wxss */

.page-pay {
  min-height: 100vh;
  background: #f7f8fa;
  padding-bottom: 140rpx;
}

/* 地址区域 */
.address-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.address-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.address-info {
  flex: 1;
}

.address-top {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #323233;
  margin-right: 20rpx;
}

.address-phone {
  font-size: 28rpx;
  color: #646566;
}

.address-detail {
  font-size: 28rpx;
  color: #646566;
  line-height: 1.5;
}

.address-arrow {
  font-size: 28rpx;
  color: #969799;
  margin-left: 20rpx;
}

.address-empty {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.empty-icon {
  font-size: 36rpx;
  color: #1989fa;
  margin-right: 12rpx;
  font-weight: bold;
}

.empty-text {
  font-size: 28rpx;
  color: #1989fa;
}

/* 商品区域 */
.goods-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #323233;
  margin-bottom: 20rpx;
}

.goods-list {
  border-top: 1rpx solid #ebedf0;
  padding-top: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx 0;
}

.goods-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #323233;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.goods-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #ee0a24;
}

.goods-count {
  font-size: 24rpx;
  color: #969799;
}

/* 备注区域 */
.remark-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  font-size: 28rpx;
}

/* 金额区域 */
.amount-section {
  background: #fff;
  padding: 30rpx;
}

.amount-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
}

.amount-label {
  font-size: 28rpx;
  color: #646566;
}

.amount-value {
  font-size: 28rpx;
  color: #323233;
}

.amount-value.free {
  color: #07c160;
}

.amount-row.total {
  border-top: 1rpx solid #ebedf0;
  padding-top: 20rpx;
  margin-top: 10rpx;
}

.amount-row.total .amount-label {
  font-weight: bold;
  color: #323233;
}

.amount-row.total .amount-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ee0a24;
}

/* 底部提交栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.total-info {
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 28rpx;
  color: #323233;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ee0a24;
  margin-left: 8rpx;
}

.submit-btn {
  padding: 24rpx 60rpx;
  background: linear-gradient(135deg, #ff6034 0%, #ee0a24 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
}

.submit-btn.disabled {
  background: #c8c9cc;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}