/* pages/login/login.wxss */

.page-login {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7f8fa 0%, #e8f4ff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

/* Logo 区域 */
.logo-section {
  margin-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #323233;
}

/* Tab 切换 */
.login-tabs {
  margin-top: 80rpx;
  width: 100%;
  display: flex;
  justify-content: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 8rpx;
}

.tab-item {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #1989fa 0%, #1976d2 100%);
}

.tab-text {
  font-size: 30rpx;
  color: #646566;
}

.tab-item.active .tab-text {
  color: #fff;
  font-weight: 500;
}

/* 登录内容区 */
.login-content {
  margin-top: 60rpx;
  width: 100%;
}

.login-tip {
  margin-bottom: 40rpx;
  text-align: center;
}

.tip-text {
  font-size: 26rpx;
  color: #969799;
}

/* 登录按钮 */
.login-buttons {
  width: 100%;
}

.btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-wx {
  background: linear-gradient(135deg, #07c160 0%, #06ad56 100%);
  color: #fff;
}

.btn-primary {
  background: linear-gradient(135deg, #1989fa 0%, #1976d2 100%);
  color: #fff;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.btn-text {
  font-weight: 500;
}

/* 表单样式 */
.login-form {
  width: 100%;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 30rpx;
  font-size: 32rpx;
  color: #323233;
  border: 2rpx solid #ebedf0;
}

.form-input:focus {
  border-color: #1989fa;
}

/* 协议 */
.agreement {
  position: fixed;
  bottom: 60rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
}

.agreement-text {
  font-size: 24rpx;
  color: #969799;
}

.agreement-link {
  font-size: 24rpx;
  color: #1989fa;
}