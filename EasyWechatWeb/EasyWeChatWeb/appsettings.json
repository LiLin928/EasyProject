{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },

  "Serilog": {
    "Elasticsearch": {
      "Enabled": false,
      "Url": "http://192.168.137.10:9200",
      "IndexFormat": "easywechat-logs-{0:yyyy.MM.dd}",
      "AutoRegisterTemplate": true,
      "MinimumLogEventLevel": "Information"
    }
  },

  "ElasticsearchQuery": {
    "Environments": {
      "Development": {
        "Url": "http://192.168.137.10:9200",
        "IndexPrefix": "easywechat-logs",
        "DefaultTimeout": 30000
      },
      "Production": {
        "Url": "http://192.168.137.10:9200",
        "IndexPrefix": "easywechat-logs",
        "DefaultTimeout": 30000
      }
    },
    "DefaultEnvironment": "Development"
  },

  "OperateLogElasticsearch": {
    "Enabled": false,
    "Url": "http://192.168.137.10:9200",
    "IndexPrefix": "operate-log",
    "WriteTimeout": 5000,
    "AsyncWrite": true
  },

  "MasterSlaveConnectionStrings": [
    {
      "ConnectionString": "Server=192.168.137.10;Port=3306;Database=EasyProject;User Id=root;Password=lilin1992;CharSet=utf8mb4;SslMode=None;AllowPublicKeyRetrieval=True;",
      "DbType": 0,
      "IsAutoCloseConnection": true,
      "InitKeyType": 1
    }
  ],

  "JWTTokenOptions": {
    "Audience": "http://localhost:7600",
    "Issuer": "http://localhost:7600",
    "SecurityKey": "EasyWeChat_SecretKey_2026_MinLength32Chars!",
    "AccessTokenExpiration": 60,
    "RefreshTokenExpiration": 10080
  },

  "WeChat": {
    "AppId": "",
    "AppSecret": "",
    "UseMock": false
  },

  "WeChatPay": {
    "AppId": "",
    "MchId": "",
    "CertSerialNumber": "",
    "PrivateKey": "",
    "ApiV3Key": "",
    "NotifyUrl": "",
    "UseMock": false
  },

  "Screen": {
    "IsUseMock": false,
    "MockDatasources": [
      { "id": "mock-mysql-1", "name": "模拟MySQL数据源", "type": "mysql" },
      { "id": "mock-postgres-1", "name": "模拟PostgreSQL数据源", "type": "postgresql" },
      { "id": "mock-api-1", "name": "模拟API数据源", "type": "api" }
    ]
  },

  "IsUseRedis": false,
  "RedisConnection": "127.0.0.1:6379,password=your_redis_pwd",

  "MinioOption": {
    "Endpoint": "192.168.137.10:9000",
    "AccessKey": "admin",
    "SecretKey": "lilin1992",
    "BucketName": "easyproject",
    "UseSSL": false
  },

  "_comment":"// 切换回 MinIO：  修改配置 'StorageType': 'minio' 即可",
  "LocalStorageOption": {
    "StorageType": "local",
    "RootPath": "uploads",
    "PublicUrlPrefix": "/uploads",
    "MaxFileSize": 52428800,
    "BaseUrl": "http://localhost:7600"
  },

  "IsUseSwagger": true,

  "OperateLog": {
    "Enabled": true,
    "ExcludePaths": [
      "/api/auth/login",
      "/api/auth/refresh",
      "/api/auth/logout",
      "/api/operatelog",
      "/swagger"
    ],
    "ExcludeGet": true
  },

  "CorsOrigins": [
    "http://localhost:3000",
    "http://localhost:8080"
  ],

  "Quartz": {
    "Enabled": false,
    "SchedulerName": "EasyWeChatScheduler",
    "ThreadCount": 10,
    "Jobs": [
      {
        "Name": "ClearLogJob",
        "Group": "System",
        "CronExpression": "0 0 2 * * ?",
        "Description": "清理超过30天的操作日志",
        "Enabled": false
      }
    ]
  },

  "Cap": {
    "Enabled": false,
    "GroupId": "EasyWeChatWeb",
    "Kafka": {
      "Servers": "192.168.137.10:9092",
      "TopicPrefix": "easywechat."
    },
    "Retry": {
      "RetryInterval": 60,
      "MaxRetryCount": 3
    }
  },

  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:7600"
      }
    }
  }
}